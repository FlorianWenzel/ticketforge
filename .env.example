# ─── GitHub ──────────────────────────────────────────────────────────────────
# Personal access token (or fine-grained token) for the bot account.
# Required scopes: repo, read:org, workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# The GitHub login (username) of the bot account.
GITHUB_BOT_USERNAME=my-bot-account

# Comma-separated list of "owner/repo" pairs the bot is allowed to act on.
# Leave blank to allow all repos (not recommended for production).
GITHUB_REPO_ALLOWLIST=myorg/myrepo,myorg/other-repo

# ─── OpenCode ─────────────────────────────────────────────────────────────────
# Base URL of the running OpenCode daemon.
OPENCODE_BASE_URL=http://localhost:4096

# Optional URL to OpenCode when TicketForge runs in Docker and OpenCode runs
# outside the container. Used as a fallback if OPENCODE_BASE_URL is unset.
OPENCODE_EXTERNAL_URL=

# Optional API key if the OpenCode server requires authentication.
OPENCODE_API_KEY=

# Model to pass in the OpenCode session (e.g. anthropic/claude-sonnet-4-6)
OPENCODE_MODEL=openai/gpt-5.3-codex

# ─── Polling intervals (cron expressions) ─────────────────────────────────────
# Job A: assignment poller
POLL_CRON_ASSIGNMENTS=*/2 * * * *

# Job B: mention poller
POLL_CRON_MENTIONS=*/2 * * * *

# Job C: CI/check watcher
POLL_CRON_CI=*/3 * * * *

# Job D: stale-work reconciler
POLL_CRON_STALE=*/20 * * * *

# ─── Worker ───────────────────────────────────────────────────────────────────
# Maximum number of work items processed concurrently across all repos.
MAX_CONCURRENT_WORKERS=3

# How many times to retry a failed work item before marking it failed.
MAX_RETRY_ATTEMPTS=3

# Minutes after which a work item in a non-terminal state is considered stale.
STALE_THRESHOLD_MINUTES=60

# ─── Persistence ──────────────────────────────────────────────────────────────
# Absolute path (or relative to CWD) for the SQLite database file.
DATABASE_PATH=./data/ticketforge.db

# ─── API server ───────────────────────────────────────────────────────────────
API_PORT=3000
API_HOST=127.0.0.1

# ─── Logging ──────────────────────────────────────────────────────────────────
# "fatal" | "error" | "warn" | "info" | "debug" | "trace"
LOG_LEVEL=info

# Set to "true" in local dev to get pretty-printed logs.
LOG_PRETTY=false
