{
  "name": "ticketforge",
  "version": "1.0.0",
  "description": "GitHub automation wrapper around OpenCode — poll, orchestrate, execute.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "swagger": "tsoa spec-and-routes",
    "start": "tsoa spec-and-routes && tsx src/index.ts",
    "dev": "tsoa spec-and-routes && tsx watch src/index.ts",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:down": "tsx scripts/migrate.ts down",
    "reset-db": "tsx scripts/reset-db.ts",
    "seed": "tsx scripts/seed.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules --import tsx/esm node_modules/.bin/jest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@octokit/plugin-retry": "^7.1.2",
    "@octokit/plugin-throttling": "^9.3.2",
    "@octokit/rest": "^21.0.2",
    "@octokit/types": "^13.6.2",
    "better-sqlite3": "^11.6.0",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "kysely": "^0.27.4",
    "node-cron": "^3.0.3",
    "pino": "^9.5.0",
    "pino-pretty": "^13.0.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
